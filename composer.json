{
    "name": "taleastromex/keepz-api-sdk",
    "description": "PHP SDK for Keepz API",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/taleastromex/keepz-api-sdk",
    "keywords": ["keepz", "payment", "sdk", "api", "php"],
    "authors": [
        {
            "name": "Davut",
            "email": "sergeev.davutt@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/taleastromex/keepz-api-sdk/issues",
        "source": "https://github.com/taleastromex/keepz-api-sdk"
    },
    "require": {
        "php": "^7.3 || ^8.0",
        "ext-openssl": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.0 || ^11.0",
        "phpstan/phpstan": "^1.0",
        "php-mock/php-mock-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Taleastromex\\KeepzApiSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Taleastromex\\KeepzApiSdk\\Tests\\": "tests/"
        }
    }
}
